# ──────────────────────────────────────────────
# MeleFlow — Environment Variables
# ──────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://taskflow:taskflow@postgres:5432/taskflow

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=change-me-to-a-random-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-to-another-random-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (must be 32 chars for AES-256)
ENCRYPTION_KEY=change-me-to-a-32-char-key-for-aes-256

# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Registration & uploads
ALLOW_REGISTRATION=true
MAX_UPLOAD_SIZE=50

# Rate limiting
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
